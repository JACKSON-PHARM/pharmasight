# =============================================================================
# KRA OSCU Gava sandbox — optional overrides for gavaetims.py only.
# Credentials are stored in test_pins.csv (gitignored), keyed by Application Test PIN.
# Each run you type the PIN; the script loads the row from the CSV (or prompts to create it).
# Never commit .env (it is gitignored). Commit .env.example only.
# =============================================================================

# Optional: paste a valid OSCU access_token to skip OAuth.
# BEARER_TOKEN=

# Optional: force a specific cmcKey (bypasses CSV cmc_key and selectInitOsdcInfo).
# CMC_KEY=
